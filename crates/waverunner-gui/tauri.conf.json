{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WaveRunner SDR",
  "version": "0.1.1",
  "identifier": "com.waverunner.sdr",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist",
    "beforeDevCommand": "cd frontend && npm run dev",
    "beforeBuildCommand": "cd frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "WaveRunner SDR",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
